{
  "name": "family-hub",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:client",
    "dev:server": "node --watch server.js",
    "dev:client": "vite --host 127.0.0.1 --config vite.config.ts",
    "build": "vite build --config vite.config.ts",
    "typecheck": "tsc --noEmit",
    "start": "node server.js",
    "backup:data": "node scripts/backup-data.mjs",
    "test:e2e": "node --test tests/e2e/*.test.js",
    "docker:build": "docker build -t family-hub:local .",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "cytoscape": "^3.33.3",
    "express": "^4.21.2",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.25.0",
    "multer": "^1.4.5-lts.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^7.0.2",
    "vite": "^6.4.3"
  }
}
