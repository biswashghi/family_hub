# Local development defaults. Copy to a local env manager if desired.
NODE_ENV=development
HOST=127.0.0.1
PORT=8787
DATA_DIR=./data

FAMILY_HUB_TIME_ZONE=America/Detroit
FAMILY_HUB_LOCATION_LABEL=Detroit, MI
FAMILY_HUB_WEATHER_LATITUDE=42.3314
FAMILY_HUB_WEATHER_LONGITUDE=-83.0458

# Keep off unless you explicitly want demo data.
FAMILY_HUB_SEED_DEMO_DATA=0

# Docker production localhost binding on the VPS.
APP_HOST_PORT=8788
